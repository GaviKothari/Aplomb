# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ── Database (Neon - Free tier: https://neon.tech) ───────────
DATABASE_URL=postgresql://user:pass@ep-xxxx.ap-south-1.aws.neon.tech/aplomb?sslmode=require
DIRECT_URL=postgresql://user:pass@ep-xxxx.ap-south-1.aws.neon.tech/aplomb?sslmode=require

# ── Redis (Upstash - Free tier: https://upstash.com) ─────────
REDIS_URL=rediss://default:xxxx@xxxx.upstash.io:6380

# ── Auth (Clerk - Free 10k MAU: https://clerk.com) ───────────
CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx
CLERK_JWT_KEY=-----BEGIN PUBLIC KEY-----
MIIBIjANBgkq...
-----END PUBLIC KEY-----

# ── Storage (Cloudflare R2 - Free 10GB/mo: https://r2.dev) ───
R2_ACCOUNT_ID=xxxx
R2_ACCESS_KEY_ID=xxxx
R2_SECRET_ACCESS_KEY=xxxx
R2_BUCKET_NAME=aplomb-media
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o

# ── Email (Resend - Free 3k/mo: https://resend.com) ──────────
RESEND_API_KEY=re_xxxx
EMAIL_FROM=noreply@aplomb.in

# ── SMS (MSG91 - India ~₹0.15/SMS) ───────────────────────────
MSG91_AUTH_KEY=xxxx
MSG91_SENDER_ID=APLOMB

# ── Google Maps ───────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=xxxx

# ── Security ─────────────────────────────────────────────────
ENCRYPTION_KEY=32-character-hex-string-for-aes256
JWT_SECRET=your-fallback-jwt-secret

# ── Rate Limiting ─────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
